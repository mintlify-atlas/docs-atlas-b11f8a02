  "keyFeatures": [
    "JWT-based authentication with secure token management",
    "Product inventory management with CRUD operations",
    "User-specific product tracking with expiry dates",
    "YOLO-based AI object detection for food items",
    "Barcode and QR code scanning capabilities",
    "Real-time WebSocket notifications for expiry alerts",
    "Automated background tasks for expiry checking",
    "Nutrition information tracking and management",
    "Usage statistics and analytics endpoints"
  ],
